set "PYTHON_MODE="

if exist "%SERVICE_DIR%\python\pythonw.exe" (
    set "PYTHON=%SERVICE_DIR%\python\pythonw.exe"
    set "PYTHON_MODE=pythonw(bundled)"
    goto :found
)
REM WorkBuddy managed Python (3.13.12)
if exist "%USERPROFILE%\.workbuddy\binaries\python\versions\3.13.12\pythonw.exe" (
    set "PYTHON=%USERPROFILE%\.workbuddy\binaries\python\versions\3.13.12\pythonw.exe"
    set "PYTHON_MODE=pythonw(managed)"
    goto :found
)
if exist "%USERPROFILE%\.workbuddy\binaries\python\versions\3.13.12\python.exe" (
    set "PYTHON=%USERPROFILE%\.workbuddy\binaries\python\versions\3.13.12\python.exe"
    set "PYTHON_MODE=python(managed)"
    goto :found
)
REM C:\Program Files\Python3x (common install location)
for %%v in (314 313 312 311 310 39) do (
    if exist "C:\Program Files\Python%%v\pythonw.exe" (
        set "PYTHON=C:\Program Files\Python%%v\pythonw.exe"
        set "PYTHON_MODE=pythonw(C:\Program Files\Python%%v)"
        goto :found
    )
    if exist "C:\Program Files\Python%%v\python.exe" (
        set "PYTHON=C:\Program Files\Python%%v\python.exe"
        set "PYTHON_MODE=python(C:\Program Files\Python%%v)"
        goto :found
    )
)
REM C:\Python3x (legacy install location)
for %%v in (314 313 312 311 310 39) do (
    if exist "C:\Python%%v\pythonw.exe" (
        set "PYTHON=C:\Python%%v\pythonw.exe"
        set "PYTHON_MODE=pythonw(C:\Python%%v)"
        goto :found
    )
    if exist "C:\Python%%v\python.exe" (
        set "PYTHON=C:\Python%%v\python.exe"
        set "PYTHON_MODE=python(C:\Python%%v)"
        goto :found
    )
)
where pythonw >nul 2>&1
if !errorlevel!==0 (
    for /f "delims=" %%p in ('where pythonw 2^>nul') do set "PYTHON=%%p"
    set "PYTHON_MODE=pythonw(PATH)"
    goto :found
)
where python >nul 2>&1
if !errorlevel!==0 (
    for /f "delims=" %%p in ('where python 2^>nul') do set "PYTHON=%%p"
    set "PYTHON_MODE=python(PATH)"
    goto :found
)

